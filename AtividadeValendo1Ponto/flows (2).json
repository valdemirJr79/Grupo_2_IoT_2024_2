    {
        "id": "d26f638e62864228",
        "type": "function",
        "z": "adb9bfbb3ac20137",
        "name": "function 1",
        "func": "// Recupera a amplitude\nlet amplitude = context.get('amplitude') || 10;\n\namplitude += 5;\nif (amplitude > 1000) {\n    amplitude = 1000;\n}\n\ncontext.set('amplitude', amplitude);\n\n// Gera valores\nlet vibX = ((Math.random() * 2 - 1) * (amplitude * 0.3)).toFixed(2);\nlet vibY = ((Math.random() * 2 - 1) * amplitude).toFixed(2);\nlet vibZ = ((Math.random() * 2 - 1) * (amplitude * 0.2)).toFixed(2);\n\n// SQL CORRETO\nmsg.topic = `\nINSERT INTO vibracao (vibX, vibY, vibXZ)\nVALUES (${vibX}, ${vibY}, ${vibZ})\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
