        "func": "let valorMax = 1000;\n\nlet valor;\n\nif(msg.topic = \"Y\"){\n\n    valor = msg.payload;\n\n    if (valor > valorMax){\n\n        msg.payload = \"ATENÇÃO: Valor fora da limiar\";\n    }else{\n        msg.payload = \"Valor dentro da limiar\";\n    }\n}\nreturn msg;",
