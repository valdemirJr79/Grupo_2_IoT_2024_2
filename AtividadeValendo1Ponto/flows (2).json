    {
        "id": "d26f638e62864228",
        "type": "function",
        "z": "adb9bfbb3ac20137",
        "name": "function 1",
        "func": "// Recupera a amplitude atual do contexto (ou começa em 10 se não existir)\nlet amplitude = context.get('amplitude') || 10;\n\n// Aumenta a amplitude gradualmente para simular o gráfico crescendo\namplitude += 5; \nif (amplitude > 1000) {\n    amplitude = 1000;\n}\n\ncontext.set('amplitude', amplitude);\n\n// Gera valores aleatórios baseados na amplitude atual\n// (Math.random() * 2 - 1) gera entre -1 e 1, multiplicamos pela amplitude\nlet vibX = ( (Math.random() * 2 - 1) * (amplitude * 0.3) ).toFixed(2);\nlet vibY = ( (Math.random() * 2 - 1) * amplitude ).toFixed(2);\nlet vibZ = ( (Math.random() * 2 - 1) * (amplitude * 0.2) ).toFixed(2);\n\nlet msgs = [];\nmsgs.push({ topic: \"X\", payload: parseFloat(vibX) });\nmsgs.push({ topic: \"Y\", payload: parseFloat(vibY) });\nmsgs.push({ topic: \"Z\", payload: parseFloat(vibZ) });\n\nreturn [msgs];",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
