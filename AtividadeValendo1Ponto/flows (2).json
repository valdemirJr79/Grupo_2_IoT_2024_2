    {
        "id": "871a14c016c54cad",
        "type": "function",
        "z": "adb9bfbb3ac20137",
        "name": "tratar valor do mqtt",
        "func": "// Pega a string que veio do MQTT\nlet texto = msg.payload;\n\n// Extrai os valores usando regex\nlet match = texto.match(/X:\\s*(-?\\d+\\.?\\d*)\\s*Y:\\s*(-?\\d+\\.?\\d*)\\s*Z:\\s*(-?\\d+\\.?\\d*)/);\n\nif (match) {\n    let vibX = parseFloat(match[1]);\n    let vibY = parseFloat(match[2]);\n    let vibZ = parseFloat(match[3]);\n\n    // Monta o SQL\n    msg.topic = `INSERT INTO vibracao (vibX, vibY, vibXZ) VALUES (${vibX}, ${vibY}, ${vibZ})`;\n\n    return msg;\n} else {\n    node.warn(\"Erro ao extrair valores\");\n    return null;\n}",
        "outputs": 1,
