    {
        "id": "9022ae5ff9feb341",
        "type": "function",
        "z": "e1f2c5560f781db9",
        "name": "Simular ADXL345",
        "func": "// Simulação de vibração do ADXL345 em 3 eixos\nlet vibX = (Math.random() * 2 - 1).toFixed(2);   // Eixo X (-1 a 1 m/s²)\nlet vibY = (Math.random() * 2 - 1).toFixed(2);   // Eixo Y (-1 a 1 m/s²)\nlet vibZ = (9.81 + (Math.random() * 0.5 - 0.25)).toFixed(2); // Eixo Z próximo da gravidade\n\n// Enviar três mensagens separadas (para o gráfico identificar cada série)\nlet msgs = [];\nmsgs.push({ topic: \"X\", payload: parseFloat(vibX) });\nmsgs.push({ topic: \"Y\", payload: parseFloat(vibY) });\nmsgs.push({ topic: \"Z\", payload: parseFloat(vibZ) });\n\nreturn [msgs];",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
